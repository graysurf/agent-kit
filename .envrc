VENV_DIR="$PWD/.venv"
export PROJECT_PATH="$PWD"

if [[ -d "$VENV_DIR/bin" ]]; then
  export VIRTUAL_ENV="$VENV_DIR"
  PATH_add "$VENV_DIR/bin"
elif [[ -d "$VENV_DIR/Scripts" ]]; then
  export VIRTUAL_ENV="$VENV_DIR"
  PATH_add "$VENV_DIR/Scripts"
else
  echo "[direnv] .venv not found; run: uv sync --locked" >&2
  return 1
fi

dotenv_if_exists .env
