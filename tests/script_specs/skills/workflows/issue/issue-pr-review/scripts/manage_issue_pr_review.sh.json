{
  "smoke": [
    {
      "name": "help-surface",
      "args": [
        "--help"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0],
        "stdout_regex": "manage_issue_pr_review\\.sh <request-followup\\|merge\\|close-pr>"
      }
    },
    {
      "name": "request-followup-dry-run",
      "args": [
        "request-followup",
        "--pr",
        "456",
        "--issue",
        "999",
        "--body",
        "Please update tests and edge-cases.",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0],
        "stdout_regex": "DRY-RUN-PR-COMMENT-URL"
      }
    },
    {
      "name": "request-followup-dry-run-structured-row-sync",
      "args": [
        "request-followup",
        "--pr",
        "456",
        "--issue",
        "999",
        "--body",
        "Please update tests and edge-cases.",
        "--row-status",
        "blocked",
        "--next-owner",
        "subagent-1",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0],
        "stdout_regex": "DRY-RUN-PR-COMMENT-URL"
      }
    },
    {
      "name": "merge-dry-run",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--close-issue",
        "--issue-comment",
        "Completed in #456",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0]
      }
    },
    {
      "name": "merge-dry-run-enforce-review-evidence",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_merge_valid.md",
        "--enforce-review-evidence",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0]
      }
    },
    {
      "name": "merge-dry-run-enforce-review-evidence-missing",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--enforce-review-evidence",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "requires --review-evidence or --review-evidence-file"
      }
    },
    {
      "name": "merge-dry-run-fail-invalid-pr-body-override",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_invalid_placeholder.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "disallowed placeholder found"
      }
    },
    {
      "name": "merge-dry-run-fail-invalid-pr-body-names-sprint-template",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_invalid_placeholder.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "schema:\\s*sprint-pr.*SPRINT_PR_TEMPLATE\\.md"
      }
    },
    {
      "name": "merge-dry-run-fail-invalid-pr-body-prints-line-number",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_invalid_placeholder.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "first match at line [0-9]+:"
      }
    },
    {
      "name": "merge-dry-run-fail-pr-body-missing-section-names-template",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_missing_section.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "missing required heading '## Issue' \\(schema: sprint-pr"
      }
    },
    {
      "name": "merge-dry-run-fail-pr-body-missing-issue-bullet",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_missing_issue_bullet.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "missing required issue bullet '- #999' \\(schema: sprint-pr"
      }
    },
    {
      "name": "merge-dry-run-fail-review-evidence-no-comment-posted",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_merge_with_fail_verdict.md",
        "--enforce-review-evidence",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_valid.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "merge decision cannot include fail/blocked core verdicts"
      }
    },
    {
      "name": "merge-dry-run-fail-pr-body-no-comment-posted",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_merge_valid.md",
        "--enforce-review-evidence",
        "--pr-body-file",
        "tests/fixtures/issue/pr_body_invalid_placeholder.md",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "disallowed placeholder found"
      }
    },
    {
      "name": "merge-dry-run-fail-review-evidence-missing-heading",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_missing_heading.md",
        "--enforce-review-evidence",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "missing required heading '## Integration Readiness' \\(schema: review-evidence"
      }
    },
    {
      "name": "merge-dry-run-fail-review-evidence-missing-required-line",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_missing_required_line.md",
        "--enforce-review-evidence",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "missing required evidence line '- Correctness verdict"
      }
    },
    {
      "name": "merge-dry-run-fail-review-evidence-decision-mismatch",
      "args": [
        "merge",
        "--pr",
        "456",
        "--method",
        "merge",
        "--issue",
        "999",
        "--review-evidence-file",
        "tests/fixtures/issue/review_evidence_decision_mismatch.md",
        "--enforce-review-evidence",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [1],
        "stderr_regex": "decision mismatch \\(expected=merge, found=request-followup\\)"
      }
    },
    {
      "name": "close-pr-dry-run-structured-outcome",
      "args": [
        "close-pr",
        "--pr",
        "456",
        "--issue",
        "999",
        "--close-reason",
        "Superseded by #457",
        "--replacement-pr",
        "#457",
        "--row-status",
        "in-progress",
        "--next-action",
        "Continue implementation on PR #457",
        "--dry-run"
      ],
      "timeout_sec": 10,
      "expect": {
        "exit_codes": [0]
      }
    }
  ]
}
